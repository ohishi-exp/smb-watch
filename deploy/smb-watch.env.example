# /etc/smb-watch/smb-watch.env  (chmod 600, root:root)
# smb-watch.service が EnvironmentFile として読む。実ファイルは host にだけ置き、
# Git / GitHub Actions には載せない (= 資格情報は host boundary に閉じる)。

# --- SMB 接続 (必須) ---
SMB_USER=CHANGEME
SMB_PASS=CHANGEME
# ドメイン / ワークグループ (不要なら空のまま)
SMB_DOMAIN=

# --- device credential (アップロード必須、Phase 2 / 案B) ---
# auth-worker の pairing (operator が browser で /device/pair) で 1 度だけ発行される。
# device_secret は再取得不可なので発行時にここへ貼る。
SMB_WATCH_DEVICE_ID=CHANGEME
SMB_WATCH_DEVICE_SECRET=CHANGEME

# --- 任意の上書き (既定で対象に一致するので通常は不要) ---
# 既定: --smb-host 172.18.21.102 / --smb-share 共有 / --smb-path 新車検証
# 既定: --auth-url https://auth.ippoan.org / --upload-url https://carins.ippoan.org
# RUST_LOG=info
# SMB_WATCH_AUTH_URL=https://auth.ippoan.org
# SMB_WATCH_UPLOAD_URL=https://carins.ippoan.org
